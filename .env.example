# =============================================================================
# PDC Payroll — Environment Variables (EXAMPLE / placeholders only)
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# =============================================================================

# --- Public (safe to expose to the browser, gated by Supabase RLS) ----------
# The NEXT_PUBLIC_ prefix means these are inlined into the client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-only (NEVER expose to the browser) ------------------------------
# No NEXT_PUBLIC_ prefix => only available in server code (server actions,
# route handlers, migrations). The service_role key bypasses RLS — keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only

# Direct Postgres password (used only for CLI migrations, never by the app).
SUPABASE_DB_PASSWORD=your-database-password
